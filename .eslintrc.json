{
    "env": {
        "commonjs": true,
        "es2021": true,
        "node": true
    },
    "extends": "airbnb-base",
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "rules": {
        "no-console":"off",
        "no-unused-vars":"off",
        "no-unused-expressions":"off",
        "quotes":"off",
        "linebreak-style":"off",
        "no-unneeded-ternary":"off",
        "no-else-return":"off",
        "operator-linebreak":"off",
        "consistent-return":"off"
    }
}
